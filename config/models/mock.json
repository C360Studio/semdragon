{
  "model_registry": {
    "endpoints": {
      "mock-llm": {
        "provider": "openai",
        "url": "http://mockllm:9090/v1",
        "model": "mock-model",
        "max_tokens": 128000,
        "supports_tools": true
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "BAAI/bge-small-en-v1.5",
        "max_tokens": 0
      }
    },
    "capabilities": {
      "agent-work": {
        "preferred": ["mock-llm"],
        "requires_tools": true
      },
      "dm-chat": {
        "preferred": ["mock-llm"]
      },
      "quest-design": {
        "preferred": ["mock-llm"]
      },
      "boss-battle": {
        "preferred": ["mock-llm"]
      },
      "embedding": {
        "description": "Vector embeddings for graph semantic search",
        "preferred": ["semembed"]
      },
      "community_summary": {
        "description": "LLM community summaries for graph clustering",
        "preferred": ["mock-llm"]
      },
      "query_classification": {
        "description": "NLQ classification for graph queries",
        "preferred": ["mock-llm"]
      }
    },
    "defaults": {
      "model": "mock-llm"
    }
  },
  "components": {
    "agentic-loop": {
      "config": {
        "context": {
          "summarization_model": "mockllm"
        }
      }
    },
    "agentic-model": {
      "config": {
        "timeout": "300s",
        "retry": { "max_attempts": 2 }
      }
    }
  }
}
