{
  "model_registry": {
    "endpoints": {
      "gemini-lite": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash-lite",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": true
      },
      "gemini-flash": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": true,
        "reasoning_effort": "low"
      },
      "gemini-pro": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-pro",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": true,
        "reasoning_effort": "medium"
      },
      "claude-sonnet": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-sonnet-4-6",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true
      },
      "claude-haiku": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-haiku-4-5-20251001",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "BAAI/bge-small-en-v1.5",
        "max_tokens": 0
      }
    },
    "capabilities": {
      "agent-work": {
        "preferred": ["claude-sonnet", "gemini-flash"],
        "requires_tools": true
      },
      "agent-work.apprentice": {
        "preferred": ["claude-haiku", "gemini-lite"],
        "requires_tools": true
      },
      "agent-work.journeyman": {
        "preferred": ["claude-sonnet", "gemini-flash"],
        "requires_tools": true
      },
      "agent-work.expert": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.master": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.grandmaster": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "quest-execution-sequential": {
        "preferred": ["claude-sonnet", "gemini-flash"],
        "requires_tools": true
      },
      "boss-battle": {
        "description": "Independent judge — different provider than agent work for unbiased review",
        "preferred": ["gemini-pro", "claude-sonnet"]
      },
      "dm-chat": {
        "preferred": ["gemini-pro", "claude-sonnet"]
      },
      "quest-design": {
        "preferred": ["gemini-pro", "claude-sonnet"]
      },
      "embedding": {
        "description": "Vector embeddings for graph semantic search",
        "preferred": ["semembed"]
      },
      "community_summary": {
        "description": "LLM community summaries for graph clustering",
        "preferred": ["gemini-lite"]
      },
      "query_classification": {
        "description": "NLQ classification for graph queries",
        "preferred": ["gemini-lite"]
      }
    },
    "defaults": {
      "model": "claude-sonnet"
    }
  },
  "components": {
    "agentic-loop": {
      "config": {
        "context": {
          "tool_result_max_age": 15,
          "summarization_model": "gemini-flash"
        }
      }
    },
    "agentic-model": {
      "config": {
        "timeout": "300s",
        "retry": { "max_attempts": 3 }
      }
    }
  }
}
