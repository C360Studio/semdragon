{
  "model_registry": {
    "endpoints": {
      "gemini-lite": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash-lite",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": false,
        "requests_per_minute": 30,
        "max_concurrent": 5
      },
      "gemini-flash": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": false,
        "reasoning_effort": "low",
        "requests_per_minute": 30,
        "max_concurrent": 5
      },
      "gemini-flash-high": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": false,
        "reasoning_effort": "high",
        "requests_per_minute": 30,
        "max_concurrent": 5
      },
      "gemini-pro": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-pro",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": false,
        "reasoning_effort": "medium",
        "requests_per_minute": 15,
        "max_concurrent": 3
      },
      "gemini-pro-high": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-pro",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": false,
        "reasoning_effort": "high",
        "requests_per_minute": 15,
        "max_concurrent": 3
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "BAAI/bge-small-en-v1.5",
        "max_tokens": 0,
        "max_concurrent": 8
      }
    },
    "capabilities": {
      "agent-work": {
        "preferred": ["gemini-flash"],
        "requires_tools": true
      },
      "agent-work.apprentice": {
        "preferred": ["gemini-lite"],
        "requires_tools": true
      },
      "agent-work.journeyman": {
        "preferred": ["gemini-flash-high", "gemini-flash"],
        "requires_tools": true
      },
      "agent-work.expert": {
        "preferred": ["gemini-pro", "gemini-flash"],
        "requires_tools": true
      },
      "agent-work.master": {
        "preferred": ["gemini-pro", "gemini-flash"],
        "requires_tools": true
      },
      "agent-work.grandmaster": {
        "preferred": ["gemini-pro", "gemini-flash"],
        "requires_tools": true
      },
      "boss-battle": {
        "preferred": ["gemini-pro", "gemini-flash"]
      },
      "dm-chat": {
        "preferred": ["gemini-pro-high", "gemini-pro", "gemini-flash"]
      },
      "quest-design": {
        "preferred": ["gemini-pro-high", "gemini-pro", "gemini-flash"]
      },
      "embedding": {
        "description": "Vector embeddings for graph semantic search",
        "preferred": ["semembed"]
      },
      "community_summary": {
        "description": "LLM community summaries for graph clustering",
        "preferred": ["gemini-lite"]
      },
      "query_classification": {
        "description": "NLQ classification for graph queries",
        "preferred": ["gemini-lite"]
      }
    },
    "defaults": {
      "model": "gemini-flash"
    }
  },
  "components": {
    "agentic-loop": {
      "config": {
        "context": {
          "tool_result_max_age": 20,
          "summarization_model": "gemini-flash"
        }
      }
    },
    "agentic-model": {
      "config": {
        "timeout": "300s",
        "retry": { "max_attempts": 3 }
      }
    }
  }
}
