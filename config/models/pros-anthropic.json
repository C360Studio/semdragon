{
  "model_registry": {
    "endpoints": {
      "claude-haiku": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-haiku-4-5-20251001",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true
      },
      "claude-sonnet": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-sonnet-4-6",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "BAAI/bge-small-en-v1.5",
        "max_tokens": 0
      }
    },
    "capabilities": {
      "agent-work": {
        "preferred": ["claude-haiku"],
        "requires_tools": true
      },

      "agent-work.expert": {
        "preferred": ["claude-haiku"],
        "requires_tools": true
      },
      "agent-work.expert.code_generation": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.expert.code_review": {
        "preferred": ["claude-haiku"],
        "requires_tools": true
      },
      "agent-work.expert.data_transformation": {
        "preferred": ["claude-haiku"],
        "requires_tools": true
      },
      "agent-work.expert.research": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.expert.analysis": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.expert.summarization": {
        "preferred": ["claude-haiku"],
        "requires_tools": true
      },
      "agent-work.expert.planning": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },

      "agent-work.master": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.master.code_generation": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.master.code_review": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.master.research": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },
      "agent-work.master.planning": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },

      "agent-work.grandmaster": {
        "preferred": ["claude-sonnet"],
        "requires_tools": true
      },

      "boss-battle": {
        "preferred": ["claude-sonnet"]
      },
      "dm-chat": {
        "preferred": ["claude-sonnet"]
      },
      "quest-design": {
        "preferred": ["claude-sonnet"]
      },
      "embedding": {
        "description": "Vector embeddings for graph semantic search",
        "preferred": ["semembed"]
      },
      "community_summary": {
        "description": "LLM community summaries for graph clustering",
        "preferred": ["claude-haiku"]
      },
      "query_classification": {
        "description": "NLQ classification for graph queries",
        "preferred": ["claude-haiku"]
      },
      "answer_synthesis": {
        "description": "Synthesize natural language answers from graph search results",
        "preferred": ["claude-haiku"]
      }
    },
    "defaults": {
      "model": "claude-haiku"
    }
  },
  "components": {
    "agentic-loop": {
      "config": {
        "context": {
          "tool_result_max_age": 20,
          "summarization_model": "claude-haiku"
        }
      }
    },
    "agentic-model": {
      "config": {
        "timeout": "300s",
        "retry": { "max_attempts": 3 }
      }
    }
  }
}
