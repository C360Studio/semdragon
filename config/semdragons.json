{
  "version": "1.0.0",
  "platform": {
    "org": "local",
    "id": "dev",
    "environment": "development"
  },
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "services": {
    "service-manager": {
      "enabled": true,
      "config": {
        "http_port": 8080,
        "swagger_ui": true,
        "server_info": {
          "title": "Semdragons API",
          "description": "Agentic workflow coordination framework",
          "version": "0.1.0"
        }
      }
    },
    "component-manager": {
      "enabled": true,
      "config": {
        "watch_config": true
      }
    },
    "game": {
      "enabled": true,
      "config": {
        "board": "board1",
        "max_entities": 1000,
        "workspace_dir": "/workspace",
        "token_budget": {
          "global_hourly_limit": 1000000,
          "endpoint_pricing": {
            "ollama-coder": { "input_per_1m_tokens": 0, "output_per_1m_tokens": 0 },
            "ollama-qwen3": { "input_per_1m_tokens": 0, "output_per_1m_tokens": 0 }
          }
        }
      }
    }
  },
  "model_registry": {
    "endpoints": {
      "ollama-coder": {
        "provider": "ollama",
        "url": "http://localhost:11434/v1",
        "model": "qwen2.5-coder:7b",
        "max_tokens": 32768,
        "supports_tools": true,
        "stream": true
      },
      "ollama-qwen3": {
        "provider": "ollama",
        "url": "http://localhost:11434/v1",
        "model": "qwen3:14b",
        "max_tokens": 40960,
        "supports_tools": false,
        "stream": true,
        "options": {
          "enable_thinking": false
        }
      }
    },
    "capabilities": {
      "agent-work": {
        "description": "Code generation and tool-calling quest execution",
        "preferred": ["ollama-coder"],
        "requires_tools": true
      },
      "boss-battle": {
        "description": "Quest output evaluation by LLM judge",
        "preferred": ["ollama-qwen3"],
        "fallback": ["ollama-coder"],
        "requires_tools": false
      },
      "quest-design": {
        "description": "DM quest parameter decisions",
        "preferred": ["ollama-qwen3"],
        "fallback": ["ollama-coder"],
        "requires_tools": false
      },
      "dm-chat": {
        "description": "DM conversational assistance",
        "preferred": ["ollama-qwen3"],
        "fallback": ["ollama-coder"],
        "requires_tools": false
      }
    },
    "defaults": {
      "model": "ollama-coder",
      "capability": "agent-work"
    }
  },
  "streams": {
    "GRAPH": {
      "subjects": [
        "graph.ingest.entity",
        "graph.export.>"
      ],
      "max_age": "24h",
      "storage": "file",
      "replicas": 1
    },
    "AGENT": {
      "subjects": [
        "agent.task.*",
        "agent.request.>",
        "agent.response.>",
        "agent.complete.*",
        "agent.failed.*",
        "agent.created.*",
        "agent.signal.*",
        "agent.context.compaction.*",
        "agent.boid.>",
        "tool.execute.*",
        "tool.result.>"
      ],
      "max_age": "72h",
      "storage": "file",
      "replicas": 1
    }
  },
  "components": {
    "websocket_input": {
      "type": "input",
      "name": "websocket_input",
      "enabled": false,
      "config": {
        "mode": "client",
        "client": {
          "url": "ws://localhost:9090/ws",
          "reconnect": {
            "enabled": true,
            "initial_delay": "1s",
            "max_delay": "30s",
            "multiplier": 2.0
          }
        },
        "ports": {
          "outputs": [{
            "name": "ws_data",
            "subject": "graph.ingest.entity",
            "type": "jetstream",
            "stream_name": "GRAPH"
          }]
        }
      }
    },
    "graph-ingest": {
      "type": "processor",
      "name": "graph-ingest",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "entities_in",
            "subject": "graph.ingest.entity",
            "type": "jetstream",
            "stream_name": "GRAPH"
          }],
          "outputs": [{
            "name": "entity_states",
            "subject": "ENTITY_STATES",
            "type": "kv-write"
          }]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "type": "processor",
      "name": "graph-index",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "entity_watch",
            "subject": "ENTITY_STATES",
            "type": "kv-watch"
          }],
          "outputs": [
            {"name": "outgoing_index", "subject": "OUTGOING_INDEX", "type": "kv"},
            {"name": "incoming_index", "subject": "INCOMING_INDEX", "type": "kv"},
            {"name": "alias_index", "subject": "ALIAS_INDEX", "type": "kv"},
            {"name": "predicate_index", "subject": "PREDICATE_INDEX", "type": "kv"}
          ]
        },
        "workers": 2,
        "batch_size": 50
      }
    },
    "graph-query": {
      "type": "processor",
      "name": "graph-query",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "query_requests",
            "subject": "graph.query.>",
            "type": "nats-request"
          }],
          "outputs": []
        },
        "request_timeout": "5s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "type": "gateway",
      "name": "graph-gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "http",
            "type": "http",
            "subject": "/graphql"
          }],
          "outputs": [
            {"name": "queries",   "type": "nats-request", "subject": "graph.query.*"},
            {"name": "mutations", "type": "nats-request", "subject": "graph.mutation.*"}
          ]
        },
        "graphql_path": "/graphql",
        "mcp_path": "/mcp",
        "bind_address": "localhost:8082",
        "enable_playground": true,
        "query_timeout": "30s"
      }
    },
    "questboard": {
      "type": "processor",
      "name": "questboard",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "default_max_attempts": 3,
        "enable_evaluation": true
      }
    },
    "bossbattle": {
      "type": "processor",
      "name": "bossbattle",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "domain": "software",
        "auto_start_on_submit": true,
        "max_concurrent": 10
      }
    },
    "agent_progression": {
      "type": "processor",
      "name": "agent_progression",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1"
      }
    },
    "agent_store": {
      "type": "processor",
      "name": "agent_store",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "enable_guild_discounts": true,
        "default_rental_uses": 10
      }
    },
    "guildformation": {
      "type": "processor",
      "name": "guildformation",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "enable_auto_formation": true,
        "enable_quorum_formation": true,
        "min_founding_members": 3,
        "formation_timeout_sec": 300
      }
    },
    "boidengine": {
      "type": "processor",
      "name": "boidengine",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "boid_suggestions_bucket": "BOID_SUGGESTIONS"
      }
    },
    "agentic-loop": {
      "type": "processor",
      "name": "agentic-loop",
      "enabled": true,
      "config": {
        "max_iterations": 20,
        "timeout": "300s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "trajectories_bucket": "AGENT_TRAJECTORIES",
        "context": {
          "enabled": true,
          "compact_threshold": 0.6,
          "tool_result_max_age": 3,
          "headroom_tokens": 6400,
          "summarization_model": "ollama-coder"
        }
      }
    },
    "agentic-model": {
      "type": "processor",
      "name": "agentic-model",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "120s",
        "retry": {
          "max_attempts": 3,
          "backoff": "exponential"
        }
      }
    },
    "questbridge": {
      "type": "processor",
      "name": "questbridge",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "domain": "software",
        "stream_name": "AGENT",
        "quest_loops_bucket": "QUEST_LOOPS",
        "max_iterations": 20,
        "enable_builtins": true,
        "default_role": "general",
        "sandbox_dir": "/workspace"
      }
    },
    "questtools": {
      "type": "processor",
      "name": "questtools",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "stream_name": "AGENT",
        "quest_loops_bucket": "QUEST_LOOPS",
        "timeout": "60s",
        "enable_builtins": true,
        "sandbox_dir": "/workspace",
        "graphql_url": "http://localhost:8082/graphql"
      }
    },
    "partycoord": {
      "type": "processor",
      "name": "partycoord",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "auto_form_parties": true,
        "require_lead_approval": false
      }
    },
    "questdagexec": {
      "type": "processor",
      "name": "questdagexec",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1"
      }
    },
    "autonomy": {
      "type": "processor",
      "name": "autonomy",
      "enabled": true,
      "config": {
        "org": "local",
        "platform": "dev",
        "board": "board1",
        "initial_delay_ms": 2000,
        "idle_interval_ms": 5000,
        "on_quest_interval_ms": 30000,
        "in_battle_interval_ms": 60000,
        "cooldown_interval_ms": 15000,
        "dm_mode": "full_auto"
      }
    }
  }
}
