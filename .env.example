# Semdragons Environment Configuration
# Copy to .env and uncomment the provider you want to use.
# Docker Compose reads .env automatically.

# ── Cloud LLM Providers ─────────────────────────────────────────────
# Set ONE of these, then start with the cloud compose override:
#   docker compose -f docker-compose.yml -f docker-compose.cloud.yml up -d

# Google Gemini (default cloud provider)
# GEMINI_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# ── Local Ollama ─────────────────────────────────────────────────────
# No key needed. Start with the Ollama compose override:
#   docker compose -f docker-compose.yml -f docker-compose.ollama.yml up -d
# Requires: ollama serve && ollama pull qwen2.5-coder:7b

# ── Agent Workspace ──────────────────────────────────────────────────
# Mount a directory for agents to read/write files during quest execution.
# Agents are sandboxed to this directory — they cannot access anything outside it.
# IMPORTANT: Scope this to a project directory, NOT your home or root filesystem.
# WORKSPACE=./my-project

# ── Seeding ──────────────────────────────────────────────────────────
# SEED_AGENTS=true        # Seed starter agents (default: true)
# SEED_E2E=true           # Full seed: agents + guilds + quests + store

# ── Auth ─────────────────────────────────────────────────────────────
# SEMDRAGONS_API_KEY=     # API key for write endpoints (empty = no auth)
