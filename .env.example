# Semdragons Environment Configuration
# Copy to .env and fill in what you need. Docker Compose reads .env automatically.

# ── Cloud LLM Providers ─────────────────────────────────────────────
# Set ONE (or more) of these. Start the stack with:
#   task docker:up            (mock LLM, no key needed)
#   task e2e:gemini           (requires GEMINI_API_KEY)
#   task e2e:anthropic        (requires ANTHROPIC_API_KEY)
#   task e2e:openai           (requires OPENAI_API_KEY)
#
# Keys are loaded from this file at startup. The model registry in
# config/semdragons.json maps capabilities to providers — if a key is
# missing the provider is skipped and the next fallback is tried.

# Google Gemini
# GEMINI_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# OpenAI (or OpenAI-compatible like OpenRouter)
# OPENAI_API_KEY=

# ── Local Ollama ─────────────────────────────────────────────────────
# No key needed:  task docker:up   (with ollama profile)
# Requires: ollama serve && ollama pull qwen2.5-coder:7b

# ── NATS ─────────────────────────────────────────────────────────────
# Override NATS connection if not using the Docker Compose default.
# Falls back to SEMSTREAMS_NATS_URLS, then config file, then nats://localhost:4222.
# SEMDRAGONS_NATS_URLS=nats://localhost:4222

# NATS auth (optional — not needed for local dev)
# SEMDRAGONS_NATS_USER=
# SEMDRAGONS_NATS_PASS=
# SEMDRAGONS_NATS_TOKEN=

# ── Backend Runtime ──────────────────────────────────────────────────
# SEMDRAGONS_CONFIG=config/semdragons.json   # Path to config file (default: config/semdragons.json)
# SEMDRAGONS_LOG_LEVEL=info                  # debug | info | warn | error (default: info)
# SEMDRAGONS_LOG_FORMAT=json                 # json | text (default: json)
# SEMDRAGONS_ENV_FILE=.env                   # Path to .env file for API key loading (default: .env)

# ── Agent Workspace ──────────────────────────────────────────────────
# Mount a directory for agents to read/write files during quest execution.
# Agents are sandboxed to this directory — they cannot access anything outside it.
# IMPORTANT: Scope this to a project directory, NOT your home or root filesystem.
# WORKSPACE=./my-project                     # (default: ./.workspace)

# ── Seeding ──────────────────────────────────────────────────────────
# SEED_AGENTS=true                           # Seed 20 starter agents (default: true)
# SEED_E2E=true                              # Full seed: agents + guilds + quests + store (default: false)

# ── Auth ─────────────────────────────────────────────────────────────
# SEMDRAGONS_API_KEY=                        # API key for write endpoints (empty = dev mode, no auth)

# ── Debugging ────────────────────────────────────────────────────────
# SEMDRAGONS_DEBUG=false                     # Enable pprof debug server (default: false)
# SEMDRAGONS_DEBUG_PORT=6060                 # pprof server port (default: 6060)

# ── Frontend ─────────────────────────────────────────────────────────
# Typically set by docker-compose or Vite, not manually:
# PUBLIC_API_URL=                            # Base URL for API calls (default: empty = relative/same-origin)
# BACKEND_PORT=8081                          # Localhost port mapping for backend (default: 8081)
